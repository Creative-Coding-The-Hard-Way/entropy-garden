---
import type SketchInfo from "../../../lib/sketch_info";
export const meta: SketchInfo = {
  tags: ["sprout", "example"],
  description: "A second example sketch",
  name: "Example 2",
  date: "2026-01-24",
};

import P5SketchLayout from "@layouts/P5SketchLayout.astro";
---

<P5SketchLayout meta={meta}>
  <script>
    import p5 from "p5";
    import { sketch } from "./_src/sketch.ts";
    new p5(sketch, document.getElementById("p5sketch")!);
  </script>
</P5SketchLayout>
